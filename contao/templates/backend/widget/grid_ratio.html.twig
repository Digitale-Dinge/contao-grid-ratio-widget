<div class="grid-ratio">
    {% set input_attributes = attrs()
        .set('type', 'hidden')
        .set('name', name)
        .set('id', id)
        .set('value', value)
        .mergeWith(attributes)
    %}
    <input{{ input_attributes }}>

    {# Column count derived from the stored fr list ("4fr 8fr" -> 2); clamped 2–4. #}
    {% set ratio_count = value|trim ? value|trim|split(' ')|length : 2 %}
    {% set ratio_count = max(2, min(4, ratio_count)) %}

    {% set columns_word = 'tl_content.gridRatioColumns'|trans({}, 'contao_tl_content') %}

    <div class="grid-ratio__field">
        <h3><label class="grid-ratio__count-label" for="{{ id }}_count">{{ columns_word }}</label></h3>
        <div class="tl_select_wrapper" data-controller="contao--choices">
            <select class="tl_select grid-ratio__count" id="{{ id }}_count">
                {% for n in 2..4 %}
                    <option value="{{ n }}"{{ n == ratio_count ? ' selected' : '' }}>{{ n }} {{ columns_word }}</option>
                {% endfor %}
            </select>
        </div>
        <p class="tl_help tl_tip" data-contao--tooltips-target="tooltip">{{ 'tl_content.gridRatioColumnsHelp'|trans({}, 'contao_tl_content') }}</p>
    </div>

    <div class="grid-ratio__field">
        <h3><label>{{ 'tl_content.gridRatioLabel'|trans({}, 'contao_tl_content') }}</label></h3>
        <div class="grid-ratio__bar" aria-hidden="true"></div>
        <p class="tl_help tl_tip" data-contao--tooltips-target="tooltip">{{ 'tl_content.gridRatioHelp'|trans({}, 'contao_tl_content') }}</p>
    </div>
</div>
