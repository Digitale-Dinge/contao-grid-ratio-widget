{% extends '@Contao/content_element/element_group.html.twig' %}
{% use '@Contao/grid/grid_ratio_attributes.html.twig' %}

{# Can be overriden to skip injecting into attributes directly #}
{% block grid_ratio_wrapper_attributes %}
    {{- block('grid_ratio_attributes') -}}
{% endblock %}

{% block attributes %}
    {% set attributes = attributes.mergeWith(block('grid_ratio_wrapper_attributes')) %}
    {{ parent() }}
{% endblock %}

{# Override this block to change the breakpoint or grid behaviour. #}
{% block grid_ratio_css %}
    {% set grid_ratio_active = data.gridRatioActive|default %}
    {% if grid_ratio_active %}
        {% add 'grid-ratio' to head %}
            <style>
                @media (width >= 768px) {
                    .grid-ratio {
                        display: grid;
                        grid-template-columns: var(--grid-cols, 1fr);
                    }
                }
            </style>
        {% endadd %}
    {% endif %}
{% endblock %}

{% block style %}
    {{ parent() }}
    {{- block('grid_ratio_css') -}}
{% endblock %}
